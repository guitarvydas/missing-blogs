#!/usr/bin/env python3
"""
Removes all double exclamation points (!!) from every .md file
in the current directory, writing changes back in place.
"""

import glob
import sys


def fix(text: str) -> tuple[str, int]:
    count = text.count("!!")
    return text.replace("!!", ""), count


def process_files(pattern: str = "*.md") -> None:
    md_files = sorted(glob.glob(pattern))

    if not md_files:
        print("No .md files found in the current directory.")
        return

    for path in md_files:
        try:
            with open(path, "r", encoding="utf-8") as fh:
                original = fh.read()
        except OSError as exc:
            print(f"  ERROR reading {path}: {exc}", file=sys.stderr)
            continue

        updated, n = fix(original)

        if n == 0:
            print(f"  {path}: no changes")
            continue

        try:
            with open(path, "w", encoding="utf-8") as fh:
                fh.write(updated)
        except OSError as exc:
            print(f"  ERROR writing {path}: {exc}", file=sys.stderr)
            continue

        print(f"  {path}: {n} occurrence(s) removed")


if __name__ == "__main__":
    process_files()
